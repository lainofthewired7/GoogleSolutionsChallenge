# Environment Variables — Projectr Analytics
# Copy this file to .env and fill in your keys

# === Database ===
DATABASE_URL=postgresql://projectr:projectr@localhost:5432/projectr_analytics

# === API Keys ===
FRED_API_KEY=your_fred_api_key_here
CENSUS_API_KEY=your_census_api_key_here
HUD_API_KEY=your_hud_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key
GEMINI_API_KEY=your_gemini_key

# === OAuth Setup (Required for Social Login) ===
# Follow Google console setup to generate credentials, otherwise 'Continue with Google' returns 501.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# === Target Market ===
DEFAULT_MARKET=austin-round-rock-tx

# === Redis Caching ===
REDIS_URL=redis://localhost:6379/0
DEFAULT_MSA_CODE=12420

# === App Config ===
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# === JWT Auth ===
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# === OAuth Providers ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
