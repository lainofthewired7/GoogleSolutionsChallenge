# Environment Variables — Projectr Analytics
# Copy this file to .env and fill in your keys

# === Database ===
DATABASE_URL=postgresql://projectr:projectr@localhost:5432/projectr_analytics

# === API Keys ===
FRED_API_KEY=your_fred_api_key_here
CENSUS_API_KEY=your_census_api_key_here
HUD_API_KEY=your_hud_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# === Target Market ===
DEFAULT_MARKET=austin-round-rock-tx
DEFAULT_MSA_CODE=12420

# === App Config ===
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
LOG_LEVEL=INFO
